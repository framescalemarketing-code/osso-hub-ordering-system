# ============================================================
# OSSO Hub Ordering System - Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Background job security
JOB_RUNNER_SECRET=set_a_long_random_secret_for_cron_calls

# BigQuery
GOOGLE_CLOUD_PROJECT_ID=
# Using ADC login locally:
# gcloud auth application-default login
# GOOGLE_APPLICATION_CREDENTIALS=./bigquery-service-account.json
BIGQUERY_DATASET=osso_hub
# The app auto-creates and evolves the BigQuery tables on first sync.
# Keep the project id set so ADC can authenticate writes at runtime.

# ClickUp
CLICKUP_API_KEY=
CLICKUP_LIST_ID=
CLICKUP_WORKSPACE_ID=

# NetSuite (leave blank to disable)
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# QuickBooks (leave blank to disable)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENVIRONMENT=sandbox

# Mailchimp (leave blank to disable)
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_LIST_ID=

# Lens vendors
NASSAU_API_URL=
NASSAU_API_KEY=
ABB_OPTICAL_API_URL=
ABB_OPTICAL_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=orders@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
