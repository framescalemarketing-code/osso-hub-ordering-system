# ============================================================
# OSSO Hub Ordering System — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xbqryfwnrbxnpsecwxsc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_2WhyFp_xXp_rqnoo1KAQ7g_WVYAWuvh
SUPABASE_Secret_KEY=your_supabase_service_role_key_here

# ── BigQuery ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=osso-hub-ordering-system
# Using ADC login locally:
# gcloud auth application-default login
# GOOGLE_APPLICATION_CREDENTIALS=./bigquery-service-account.json
BIGQUERY_DATASET=osso_hub

# ── ClickUp ──────────────────────────────────────────────
CLICKUP_API_KEY=
CLICKUP_LIST_ID=
CLICKUP_WORKSPACE_ID=

# ── NetSuite (plug-and-play, leave blank to disable) ─────
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# ── QuickBooks (plug-and-play, leave blank to disable) ───
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ENVIRONMENT=sandbox

# ── Mailchimp (plug-and-play, leave blank to disable) ────
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_LIST_ID=

# ── Lens Vendors ─────────────────────────────────────────
NASSAU_API_URL=
NASSAU_API_KEY=
ABB_OPTICAL_API_URL=
ABB_OPTICAL_API_KEY=

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=orders@yourdomain.com

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
